<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MightyBoost - Windows 10/11 Optimizer"
        Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <SolidColorBrush x:Key="BgDark"        Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#FF252526"/>
        <SolidColorBrush x:Key="BgPanelDark"   Color="#FF181818"/>
        <SolidColorBrush x:Key="Accent"        Color="#FF0E639C"/>
        <SolidColorBrush x:Key="AccentHover"   Color="#FF1177BB"/>
        <SolidColorBrush x:Key="Text"          Color="#FFEAEAEA"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#FFB0B0B0"/>
        <SolidColorBrush x:Key="Warn"          Color="#FFE0A458"/>
        <SolidColorBrush x:Key="Danger"        Color="#FFE05858"/>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#FF333333" BorderThickness="0,0,0,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgDark}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF2D2D30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgPanelDark}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock Text="⚡" FontSize="24" Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                    <TextBlock Text="MightyBoost" FontSize="20" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Windows 10/11 Optimizer" Foreground="{StaticResource TextMuted}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="HeaderVersion" Text="v0.1.0"
                           Foreground="{StaticResource TextMuted}"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="{StaticResource BgDark}" BorderThickness="0">

            <TabItem Header="🏠 Home">
                <Grid Margin="20">
                    <StackPanel>
                        <TextBlock Text="System status" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                        <Border Background="{StaticResource BgPanel}" CornerRadius="4" Padding="18">
                            <TextBlock x:Name="HomeStatusText" Foreground="{StaticResource Text}"
                                       TextWrapping="Wrap" FontFamily="Consolas" FontSize="13"/>
                        </Border>
                        <TextBlock Text="Presets" FontSize="18" FontWeight="Bold" Margin="0,24,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnApplyPresetSafe"       Content="Safe preset"/>
                            <Button x:Name="BtnApplyPresetBalanced"   Content="Balanced preset"/>
                            <Button x:Name="BtnApplyPresetAggressive" Content="Aggressive preset" Background="{StaticResource Danger}"/>
                            <Button x:Name="BtnRestorePoint"          Content="Create restore point"
                                    Background="{StaticResource Warn}" Foreground="#FF1E1E1E"/>
                        </StackPanel>
                        <TextBlock Margin="0,24,0,0" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                                   Text="Backups for every change are stored in %AppData%\MightyBoost\Backups. Each apply also creates a System Restore Point. You can undo any change from the Restore tab."/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="📦 Install">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Install programs via winget" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanelInstall"/>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="BtnInstallApps" Content="Install selected"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="🔒 Privacy">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Privacy and telemetry tweaks" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanelPrivacy"/>
                    </ScrollViewer>
                    <Button Grid.Row="2" x:Name="BtnApplyTweaks" Content="Apply selected tweaks"
                            HorizontalAlignment="Left" Margin="0,12,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="⚡ Performance">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Performance and UI tweaks" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Performance" FontWeight="Bold" Margin="0,4,0,4"/>
                            <StackPanel x:Name="PanelPerformance"/>
                            <TextBlock Text="Gaming"      FontWeight="Bold" Margin="0,12,0,4"/>
                            <StackPanel x:Name="PanelGaming"/>
                            <TextBlock Text="Network"     FontWeight="Bold" Margin="0,12,0,4"/>
                            <StackPanel x:Name="PanelNetwork"/>
                            <TextBlock Text="UI/Explorer" FontWeight="Bold" Margin="0,12,0,4"/>
                            <StackPanel x:Name="PanelUI"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="🗑️ Debloat">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Remove built-in apps (Appx)" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanelDebloat"/>
                    </ScrollViewer>
                    <Button Grid.Row="2" x:Name="BtnApplyDebloat" Content="Remove selected"
                            Background="{StaticResource Danger}" HorizontalAlignment="Left" Margin="0,12,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="⚙️ Services">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Windows services" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanelServices"/>
                    </ScrollViewer>
                    <Button Grid.Row="2" x:Name="BtnApplyServices" Content="Apply selected"
                            HorizontalAlignment="Left" Margin="0,12,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="🧹 Cleanup">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Cleanup junk and caches" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PanelCleanup"/>
                    </ScrollViewer>
                    <Button Grid.Row="2" x:Name="BtnRunCleanup" Content="Run cleanup"
                            HorizontalAlignment="Left" Margin="0,12,0,0"/>
                </Grid>
            </TabItem>

            <TabItem Header="↩️ Restore">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Applied actions - select to undo" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ListBox x:Name="UndoList" Grid.Row="1" Background="{StaticResource BgPanel}"
                             Foreground="{StaticResource Text}" BorderBrush="#FF333333"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="BtnRefreshUndo"  Content="Refresh"/>
                        <Button x:Name="BtnUndoSelected" Content="Undo selected" Background="{StaticResource Warn}" Foreground="#FF1E1E1E"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="📝 Log">
                <Grid Margin="20">
                    <Border Background="{StaticResource BgPanel}" CornerRadius="4" Padding="14">
                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMuted}">
                            Session log is written to:
                            <LineBreak/>
                            <Run x:Name="LogPathText" FontFamily="Consolas" Foreground="#FF9CDCFE"/>
                            <LineBreak/><LineBreak/>
                            Backups: %AppData%\MightyBoost\Backups
                            <LineBreak/>
                            Applied history: %AppData%\MightyBoost\applied.json
                        </TextBlock>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <Border Grid.Row="2" Background="{StaticResource BgPanelDark}">
            <TextBlock Text="MightyBoost · MIT · github.com/sadawdawdsdads/mighty-boost"
                       Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="20,0,0,0"
                       FontSize="11"/>
        </Border>
    </Grid>
</Window>
